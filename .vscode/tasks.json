{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Script: install",
            "type": "npm",
            "script": "install",
            "problemMatcher": [],
            "detail": "Run npm install to install dependencies"
        },
        {
            "label": "Run Script: dev",
            "type": "shell",
            "command": "npm run dev",
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "pattern": {
                    "regexp": ".",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "vite v\\d+\\.\\d+\\.\\d+",
                    "endsPattern": "http://localhost:\\d+/?"
                }
            }
        },
        {
            "label": "Run Script: install and dev",
            "dependsOn": ["Run Script: install", "Run Script: dev"],
            "dependsOrder": "sequence"
        },
        {
            "label": "Activate .venv",
            "type": "shell",
            "command": "source .venv/bin/activate",
            "problemMatcher": [] 
        },
        {
            "label": "Launch Browser",
            "type": "shell",
            "command": "start http://localhost:8080",
            "problemMatcher": []
        },
        {
            "label": "Activate .venv and Launch Browser",
            "dependsOn": ["Activate .venv", "Launch Browser"],
            "dependsOrder": "sequence"
        }
    ]
}